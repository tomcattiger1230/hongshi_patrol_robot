# 海康主码流通常为 101，子码流通常为 102。
CAMERA_RTSP_URL=rtsp://192.168.1.64:554/Streaming/Channels/101
CAMERA_USER=admin
CAMERA_PASSWORD=change-this-camera-password
CAMERA_ONVIF_PORT=80
CAMERA_PROFILE_TOKEN=Profile_101

# 本地 Web 页面通过 NUC 的 PTZ Agent 控制摄像头。
PTZ_BIND_HOST=0.0.0.0
PTZ_AGENT_PORT=8090
PTZ_TOKEN=change-this-independent-ptz-token
PTZ_DEADMAN_SECONDS=1.5

# NUC 局域网 RTSP 代理，账号密码应与 local/.env 的 READ_* 一致。
LOCAL_READ_USER=local_viewer
LOCAL_READ_PASSWORD=change-this-local-read-password
LOCAL_RTSP_PORT=8554
GO2RTC_BIN=/home/robot/go2rtc/go2rtc_linux_amd64

# 公网服务器地址，不要带 rtsp://。
SERVER_HOST=203.0.113.10
SERVER_PORT=8554
STREAM_PATH=robot
PUBLISH_USER=robot_publisher
PUBLISH_PASSWORD=change-this-publish-password

# copy 几乎不占 CPU；若摄像头输出格式无法播放，可改为 transcode。
VIDEO_MODE=copy
# transcode 时默认用 CPU；Intel NUC 可在 FFmpeg 支持时改成 h264_qsv。
VIDEO_ENCODER=libx264
VIDEO_BITRATE=2500k
VIDEO_FPS=25
FFMPEG_LOG_LEVEL=warning
RECONNECT_MIN_SECONDS=2
RECONNECT_MAX_SECONDS=30
