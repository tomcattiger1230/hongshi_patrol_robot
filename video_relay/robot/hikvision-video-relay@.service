[Unit]
Description=Hikvision camera public RTSP relay (%i)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=%i
WorkingDirectory=/opt/hikvision-video-relay/robot
ExecStart=/usr/bin/python3 /opt/hikvision-video-relay/robot/push_stream.py
Restart=always
RestartSec=3
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
